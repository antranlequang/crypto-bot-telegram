# ===== TELEGRAM BOT =====
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional: secondary bot for monitoring/logging
SECONDARY_BOT_TOKEN=your_secondary_bot_token_here
# Chat ID to receive monitoring logs (user/group/channel)
MONITOR_CHAT_ID=your_monitor_chat_id_here

# ===== CRYPTO DATA API =====
# CoinDesk API (for OHLCV and on-chain data retrieval)
COINDESK_API_KEY=your_coindesk_api_key_here

# ===== NEWS / SENTIMENT API =====
# Sentiment provider: alpha | gnews | off
SENTIMENT_PROVIDER=alpha
# Alpha Vantage NEWS_SENTIMENT API (required for news/sentiment features)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
# CoinMarketCal (optional)
COINMARKETCAL_API_KEY=your_coinmarketcal_api_key_here
# Twitter (optional, for potential future use)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
# Reddit (optional)
REDDIT_USER_AGENT=crypto-telegram-bot/1.0

# ===== LLM / RAG (Gemini via Vertex AI) =====
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_PROJECT_ID=your_google_project_id_here
GOOGLE_LOCATION=us-central1

# ===== MACRO DATA =====
FRED_API_KEY=your_fred_api_key_here

# ===== FEATURE TOGGLES =====
USE_MACRO_DATA=1
USE_RISK_SCORE=0
